{
  "name": "nneesstt",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "sync:questions": "ts-node -r tsconfig-paths/register scripts/run-question-sync.ts",
    "sync:audio": "ts-node -r tsconfig-paths/register scripts/sync-audio.ts",
    "sync:georgian": "ts-node -r tsconfig-paths/register scripts/sync-georgian.ts",
    "sync:georgian:test1": "ts-node -r tsconfig-paths/register scripts/sync-georgian.ts --limit=1",
    "sync:recover": "ts-node -r tsconfig-paths/register scripts/recover-questions.ts",
    "sync:translate-correct": "ts-node -r tsconfig-paths/register scripts/translate-and-correct.ts",
    "import:questions:csv": "ts-node -r tsconfig-paths/register scripts/import-questions-from-csv.ts",
    "import:questions": "ts-node -r tsconfig-paths/register scripts/import-questions-from-csv.ts",
    "db:test-pg": "ts-node -r tsconfig-paths/register scripts/test-pg-connection.ts",
    "db:migrate-questions-to-pg": "ts-node -r tsconfig-paths/register scripts/migrate-questions-to-postgres.ts",
    "db:migrate-categories-to-pg": "ts-node -r tsconfig-paths/register scripts/migrate-categories-to-postgres.ts",
    "db:migrate-exams-to-pg": "ts-node -r tsconfig-paths/register scripts/migrate-exams-to-postgres.ts",
    "db:migrate-mysql-to-pg": "ts-node -r tsconfig-paths/register scripts/migrate-mysql-to-postgres.ts",
    "db:seed-categories": "ts-node -r tsconfig-paths/register scripts/seed-categories-from-questions.ts",
    "db:verify-questions": "ts-node -r tsconfig-paths/register scripts/verify-questions-import.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/lib-storage": "^3.997.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "mongodb": "^7.1.1",
    "mongoose": "^9.1.6",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
