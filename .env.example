# Database — PostgreSQL (Neon / Render / Docker)
DB_TYPE=postgres
DB_SYNCHRONIZE=false

# Preferred for hosted Postgres (Neon, Render, etc.)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Local Docker fallback (when DATABASE_URL is unset)
PG_HOST=localhost
PG_PORT=5432
PG_USERNAME=postgres
PG_PASSWORD=your_postgres_password
PG_DATABASE=driving_theory_back

# Legacy — only for one-time migration scripts (optional)
# DB_HOST=localhost
# DB_PORT=3306
# MONGODB_URI=...
# MONGODB_DB=exam

# JWT Secret (use a strong random string)
JWT_SECRET=your-jwt-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public API URL as seen by the browser (required in production for Google OAuth)
API_PUBLIC_URL=https://api.prava.ucos.ge

# Optional if API_PUBLIC_URL is set — must match Google Console exactly
GOOGLE_CALLBACK_URL=https://api.prava.ucos.ge/auth/google/callback
GOOGLE_REDIRECT_AFTER_LOGIN=https://prava.ucos.ge

# CORS — comma-separated frontend origins (required in production)
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

# Set automatically on Render; use production locally only when testing cross-origin cookies
# NODE_ENV=production
AWS_REGION=eu-north-1
AWS_S3_BUCKET=prava-ge-assets
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_PUBLIC_BASE_URL=https://prava-ge-assets.s3.eu-north-1.amazonaws.com